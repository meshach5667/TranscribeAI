# ─── TranscrybeAI Environment Variables ───

# Required: Google Gemini API key (used for transcription, chat, and LangChain summarisation)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Drive API key (for downloading public Drive files without a service account)
GOOGLE_DRIVE_API_KEY=

# Optional: Path to a Google Cloud service-account JSON file
# Fallback for fetching private Drive files when user is not signed in
# GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

# Required: Google OAuth 2.0 credentials (for user authentication + private Drive access)
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/callback